APP_NAME=CreativePOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=creativepos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=creativepos_

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default platform mailer (fallback bila tenant belum set SMTP di Pengaturan → Integrasi)
# log = dev (email masuk storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@creativepos.app"
MAIL_FROM_NAME="${APP_NAME}"

# Contoh SMTP per tenant (disimpan via API /settings/integrations/email):
# Gmail:     smtp.gmail.com, port 587, tls, gunakan App Password
# Mailtrap:  sandbox.smtp.mailtrap.io, port 587, tls
# Mailpit:   127.0.0.1, port 1025, tanpa enkripsi (dev lokal)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
# Cloudflare / reverse proxy (set * saat di belakang CDN)
TRUSTED_PROXIES=
SANCTUM_TOKEN_PREFIX=

# Multi-tenant
TENANT_HEADER=X-Tenant-ID
TENANT_DOMAIN_SUFFIX=creativepos.app

# CreativePOS
CREATIVEPOS_TRIAL_DAYS=14
CREATIVEPOS_OTP_EXPIRY_MINUTES=5
CREATIVEPOS_OTP_MAX_ATTEMPTS=5
CREATIVEPOS_LOGIN_MAX_ATTEMPTS=5
CREATIVEPOS_LOGIN_LOCKOUT_MINUTES=15
CREATIVEPOS_TOKEN_EXPIRY_DAYS=30

# Horizon
HORIZON_PREFIX=creativepos_horizon:

# Reverb (WebSocket)
REVERB_APP_ID=creativepos
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# WhatsApp (OTP & Notifications — tenant config via Settings)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Firebase Cloud Messaging (push notifications)
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend (payment redirect)
FRONTEND_URL=http://localhost:3000

# Akun default (diisi oleh DefaultAccountsSeeder saat migrate --seed)
# CREATIVEPOS_DEMO_ADMIN_EMAIL=admin@creativepos.local
# CREATIVEPOS_DEMO_ADMIN_PASSWORD=Admin123!
# CREATIVEPOS_SUPER_ADMIN_EMAIL=superadmin@creativepos.local
# CREATIVEPOS_SUPER_ADMIN_PASSWORD=SuperAdmin123!
# SKIP_DEFAULT_ACCOUNTS=1

# SaaS Billing — Midtrans (VA, QRIS, E-Wallet)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# SaaS Billing — Xendit (recurring subscription, kartu kredit)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=