# CreativePOS — Docker environment (client / on-premise)
# Salin ke docker/.env lalu sesuaikan

# Port HTTP yang dibuka ke jaringan (default 80)
APP_PORT=80

# Host/IP server — dipakai saat generate backend/.env dan frontend/.env.local
# Contoh LAN: 192.168.1.50  |  Hostname: pos.toko-saya.local
APP_HOST=192.168.1.50

# Database (sinkron dengan backend/.env)
DB_DATABASE=creativepos
DB_USERNAME=creativepos
DB_PASSWORD=GantiPasswordKuat123!
DB_ROOT_PASSWORD=GantiRootPassword123!